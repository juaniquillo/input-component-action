{
    "name": "juaniquillo/input-component-action",
    "description": "Form input component creation and management action for Crud Assistant",
    "license": "MIT",
    "homepage": "https://github.com/juaniquillo/input-component-action",    
    "authors": [
        {
            "name": "Juaniquillo",
            "email": "juaniquillo@gmail.com"
        }
    ],
    "require": {
        "juaniquillo/crud-assistant": "^0.1.0",
        "juaniquillo/laravel-backend-component": "^0.1.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.9",
        "larastan/larastan": "^3.9",
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "Juaniquillo\\InputComponentAction\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "qa": [
            "@composer run format",
            "@composer run analyse",
            "@composer run test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Juaniquillo\\InputComponentAction\\InputComponentActionServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
